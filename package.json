{
  "name": "quickbite-pos-&-inventory",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'npm run dev:site & npm run dev:sistema & wait'",
    "dev:site": "npm run dev --prefix SITElanchesdoben",
    "dev:sistema": "vite",
    "build": "npm run build:site && npm run build:sistema && npm run build:merge",
    "build:site": "npm run build --prefix SITElanchesdoben -- --outDir ../.tmp/site-dist",
    "build:sistema": "vite build --outDir .tmp/sistema-dist",
    "build:merge": "node scripts/merge-builds.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
