# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Caminho do sistema na mesma origem do site (padrão: /sistema)
VITE_ADMIN_SYSTEM_PATH="/sistema"

# Target do proxy local para /sistema (somente desenvolvimento do site institucional).
# Exemplo padrão: sistema rodando no projeto principal em localhost:3001
VITE_ADMIN_PROXY_TARGET="http://localhost:3001"

# Endpoint do backend compartilhado com o sistema de caixa para carregar o cardápio público.
# Se não for informado, o site usa o fallback local seguro.
VITE_API_BASE_URL="http://127.0.0.1:4000"

# Domínio do site institucional em produção (usado como fallback no SSR estático).
VITE_SITE_ORIGIN_FALLBACK="https://xburgerpdv.com.br"

# Identidade visual e canais de contato (site institucional).
VITE_SITE_BRAND_NAME="XBURGER"
VITE_SITE_COPYRIGHT_DOMAIN="xburgerpdv.com.br"
VITE_SITE_WHATSAPP_NUMBER="5511000000000"
VITE_SITE_PHONE_DISPLAY="(11) 90000-0000"
VITE_SITE_MAPS_URL="https://maps.google.com/"
VITE_SITE_INSTAGRAM_URL="https://www.instagram.com/xburgerpdv/"
VITE_SITE_FACEBOOK_URL="https://www.facebook.com/xburgerpdv/"
